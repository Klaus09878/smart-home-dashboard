# Cloudflare Pages Sicherheits-Header fuer alle Seiten.
# CSP: script-src OHNE 'unsafe-inline' — Inline-onclick-Handler wurden durch
# Event-Delegation ersetzt (P2-8); der einzige Inline-Bootstrap (Theme-Snippet
# in index.html/gpx.html, identisch) ist per 'sha256-...' freigegeben. Aendert
# sich das Snippet, muss der Hash neu berechnet werden (der Smoke-Test prueft das).
# style-src behaelt 'unsafe-inline' (dynamische Inline-styles fuer Balken/Charts).
# connect-src listet alle vom Client direkt kontaktierten Fremd-Hosts; alles
# andere laeuft ueber gleiche Herkunft (/api/*). Aenderungen an Fetch-Zielen
# hier nachziehen.
# Vendor-Bibliotheken 7 Tage cachen (P3-10). BEWUSST kein 'immutable': die
# Dateinamen tragen keine Version — bei einem Vendor-Upgrade die Datei umbenennen
# oder diese Cache-Zeit beachten, sonst haengen alte Bibliotheken im Cache fest.
/vendor/*
  Cache-Control: public, max-age=604800

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-eLZhyzXdu32xZFF/i0jEbzBcH5z949HuC9z7s5q31EY='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://tile.openstreetmap.org https://*.tile.openstreetmap.org; connect-src 'self' https://ntfy.sh https://api.open-meteo.com https://archive-api.open-meteo.com https://geocoding-api.open-meteo.com https://air-quality-api.open-meteo.com https://api.brightsky.dev https://nominatim.openstreetmap.org; manifest-src 'self'; worker-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(self), camera=(self), microphone=(), interest-cohort=()
