# Cloudflare Pages Sicherheits-Header fuer alle Seiten.
# CSP: script-src/style-src brauchen 'unsafe-inline', weil das Markup Inline-
# onclick-Handler und einen Inline-Theme-Bootstrap nutzt (siehe index.html).
# connect-src listet alle vom Client direkt kontaktierten Fremd-Hosts; alles
# andere laeuft ueber gleiche Herkunft (/api/*). Aenderungen an Fetch-Zielen
# hier nachziehen.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://tile.openstreetmap.org https://*.tile.openstreetmap.org; connect-src 'self' https://ntfy.sh https://api.open-meteo.com https://archive-api.open-meteo.com https://geocoding-api.open-meteo.com https://air-quality-api.open-meteo.com https://nominatim.openstreetmap.org; manifest-src 'self'; worker-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
